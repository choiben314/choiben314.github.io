---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
}

const {
  title = "Ben Choi",
  description = "Ben Choi's personal website.",
  wide = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Literata:opsz,wght@7..72,400;7..72,500;7..72,600&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <div class:list={["wrap", wide && "wrap-wide"]}>
      <slot />
    </div>
  </body>
</html>
